  "keyFeatures": [
    "60-90% token reduction on common dev commands",
    "Zero-overhead CLI proxy (<10ms startup)",
    "Smart filtering strategies (grouping, truncation, deduplication)",
    "Git, testing, linting, and container command support",
    "Claude Code integration via auto-rewrite hooks",
    "Token analytics and usage tracking with SQLite",
    "Discover command to find missed savings opportunities",
    "Tee recovery for full output on failures",
    "Multi-language support (JavaScript, Python, Go, Rust)",
    "Cross-platform (macOS, Linux, Windows)"
  ],
  "publicApiSurface": [
    "rtk ls - Token-optimized directory listing",
    "rtk read - Smart file reading with filter levels",
    "rtk grep - Grouped search results",
    "rtk git - Compact git operations (status, log, diff, commit, push)",
    "rtk test - Show test failures only",
    "rtk lint - Grouped linting errors (ESLint, Biome, Ruff)",
    "rtk cargo/npm/go - Language-specific test runners",
    "rtk gain - Token savings analytics",
    "rtk discover - Find missed RTK opportunities",
